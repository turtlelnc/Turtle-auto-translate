{
  "manifest_version": 3,
  "name": "自动翻译助手",
  "version": "1.1.0",
  "description": "一键将网页从英文翻译为中文，支持谷歌翻译、MyMemory、LibreTranslate（均免费）及DeepL、AI等多种翻译服务。",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "自动翻译助手"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/translate.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
